# MongoDB Atlas — Connection string (Database → Connect → Drivers)
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos (opcional, por defecto: niku)
MONGODB_DB_NAME=niku

# Solo desarrollo local — URL del frontend para CORS
CLIENT_ORIGIN=http://localhost:5173

# OpenAI — transcripción (Whisper) y análisis de sesión (resumen, wiki, PJ)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Vercel Blob — subida de audios de sesión (hasta ~100 MB, subida directa desde el navegador)
BLOB_READ_WRITE_TOKEN=

# Tras transcribir con IA, el audio en Blob se borra (queda la transcripción). Para conservarlo: AUDIO_KEEP_AFTER_TRANSCRIBE=true
# AUDIO_KEEP_AFTER_TRANSCRIBE=true

# URL pública de la app (invitaciones y emails)
PUBLIC_APP_URL=https://tu-app.vercel.app

# Email (login + avisos al master)
RESEND_API_KEY=
RESEND_FROM=Niku <onboarding@resend.dev>

# Discord — webhook para avisos cuando un jugador pide entrar
DISCORD_WEBHOOK_URL=

# Bot Discord opcional (integrations/discord-bot.mjs)
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
